<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="AskEiva.WebUI.styles.css" />
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>
<body>
    <Routes @rendermode="InteractiveServer" />

    <div id="mudblazor-root-providers">
        <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    </div>

    <script src="_framework/blazor.web.js"></script>
    
    <script src="https://unpkg.com/vis-network/standalone/umd/vis-network.min.js"></script>
    
    <script>
        window.eivaGraphInterop = {
            renderNetworkGraph: function (containerId, nodesArray, edgesArray) {
                const container = document.getElementById(containerId);
                if (!container) return;

                // Format raw .NET objects into vis.js expected schemas
                const data = {
                    nodes: new vis.DataSet(nodesArray),
                    edges: new vis.DataSet(edgesArray)
                };

                // Enterprise Styling Configuration
                const options = {
                    nodes: {
                        shape: 'dot',
                        size: 24,
                        font: { size: 14, color: '#0A2540', face: 'Segoe UI' },
                        borderWidth: 2,
                        shadow: true
                    },
                    edges: {
                        width: 2,
                        color: { color: '#94A3B8', hover: '#0A2540', highlight: '#0284C7' },
                        arrows: { to: { enabled: true, scaleFactor: 0.8 } },
                        font: { size: 11, align: 'top', color: '#64748B' },
                        smooth: { type: 'continuous' }
                    },
                    interaction: { 
                        hover: true,
                        navigationButtons: true,
                        keyboard: true
                    },
                    physics: {
                        barnesHut: { gravitationalConstant: -3000, centralGravity: 0.3, springLength: 95 },
                        stabilization: { iterations: 150 }
                    }
                };

                // Initialize canvas network viewport instance
                new vis.Network(container, data, options);
            }
        };
    </script>
</body>

</html>