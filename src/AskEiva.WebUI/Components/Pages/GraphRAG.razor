@page "/graphrag"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer

@using MediatR
@using AskEiva.Application.Graphs.Queries
@inject IMediator Mediator
@inject IJSRuntime JSRuntime

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudGrid Justify="Justify.Center">
        <MudItem xs="10" Style="min-height: calc(100vh - 160px); display: flex; flex-direction: column; gap: 16px;">
            
            <MudPaper Elevation="0" Class="pa-4 d-flex align-center justify-space-between" Style="border: 1px solid #E2E8F0; background: #FFFFFF; border-radius: 8px;">
                <div class="d-flex align-center gap-3">
                    <MudIcon Icon="@Icons.Material.Filled.Hub" Color="Color.Primary" Size="Size.Medium" />
                    <MudText Typo="Typo.h6" Style="color: #0A2540; font-weight: 600;">Entity Relationship Graph</MudText>
                </div>
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Primary" 
                           Size="Size.Small" 
                           StartIcon="@Icons.Material.Filled.Refresh" 
                           OnClick="() => LoadGraphDataAsync()"
                           Disabled="_isGraphLoading">
                    @(_isGraphLoading ? "Syncing..." : "Refresh Graph")
                </MudButton>
            </MudPaper>

            <MudPaper Elevation="0" Class="flex-grow-1 d-flex align-center justify-center relative shadow-sm" Style="border: 1px solid #E2E8F0; background: #F8FAFC; border-radius: 8px; overflow: hidden; min-height: 450px; height: 50vh;">
                @if (_isGraphLoading)
                {
                    <div class="text-center" style="z-index: 10;">
                        <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" Class="mb-2" />
                        <MudText Typo="Typo.caption" Class="d-block" Style="color: #64748B;">Querying Weaviate semantic index networks...</MudText>
                    </div>
                }

                <div id="eivaGraphViewport" style="width: 100%; height: 100%; position: absolute; top: 0; left: 0; visibility: @(_isGraphLoading ? "hidden" : "visible");"></div>
            </MudPaper>

            <MudPaper Elevation="0" Class="pa-3" Style="border: 1px solid #E2E8F0; background: #FFFFFF; border-radius: 8px;">
                <div class="d-flex align-center gap-3">
                    <MudTextField @bind-Value="_graphSearchQuery" 
                                  Placeholder="Search graph entities or predicates (e.g., ScanFish, NaviSuite, initialized_by)..." 
                                  Variant="Variant.Text" 
                                  Underline="false"
                                  OnKeyDown="HandleGraphSearchKeyDown"
                                  Immediate="true"
                                  Class="flex-grow-1" />
                    <MudIconButton Icon="@Icons.Material.Filled.Search" 
                                   Color="Color.Primary" 
                                   OnClick="() => LoadGraphDataAsync(_graphSearchQuery)" 
                                   Disabled="_isGraphLoading" />
                </div>
            </MudPaper>

            @if (_graphMetrics != null)
            {
                <div class="d-flex gap-4 justify-space-between mt-1">
                    <MudPaper Elevation="0" Class="pa-4 flex-grow-1 text-center" Style="border: 1px solid #E2E8F0; background: #FFFFFF; border-radius: 8px; width: 25%;">
                        <MudText Typo="Typo.caption" Class="font-weight-bold d-block mb-1" Style="color: #64748B; text-transform: uppercase; letter-spacing: 0.5px;">Knowledge Triples</MudText>
                        <MudText Typo="Typo.h5" Class="font-weight-bold" Style="color: #0A2540;">@_graphMetrics.TotalTriples.ToString("N0")</MudText>
                    </MudPaper>

                    <MudPaper Elevation="0" Class="pa-4 flex-grow-1 text-center" Style="border: 1px solid #E2E8F0; background: #FFFFFF; border-radius: 8px; width: 25%;">
                        <MudText Typo="Typo.caption" Class="font-weight-bold d-block mb-1" Style="color: #64748B; text-transform: uppercase; letter-spacing: 0.5px;">Unique Entities</MudText>
                        <MudText Typo="Typo.h5" Class="font-weight-bold" Style="color: #0284C7;">@_graphMetrics.TotalNodes.ToString("N0")</MudText>
                    </MudPaper>

                    <MudPaper Elevation="0" Class="pa-4 flex-grow-1 text-center" Style="border: 1px solid #E2E8F0; background: #FFFFFF; border-radius: 8px; width: 25%;">
                        <MudText Typo="Typo.caption" Class="font-weight-bold d-block mb-1" Style="color: #64748B; text-transform: uppercase; letter-spacing: 0.5px;">Semantic Density</MudText>
                        <MudText Typo="Typo.h5" Class="font-weight-bold" Style="color: #059669;">@_graphMetrics.SemanticDensity.ToString("F2")</MudText>
                    </MudPaper>

                    <MudPaper Elevation="0" Class="pa-4 flex-grow-1 text-center" Style="border: 1px solid #E2E8F0; background: #FFFFFF; border-radius: 8px; width: 25%;">
                        <MudText Typo="Typo.caption" Class="font-weight-bold d-block mb-1" Style="color: #64748B; text-transform: uppercase; letter-spacing: 0.5px;">Sub-Graph Clusters</MudText>
                        <MudText Typo="Typo.h5" Class="font-weight-bold" Style="color: #7C3AED;">@_graphMetrics.ConnectedClusters.ToString("N0")</MudText>
                    </MudPaper>
                </div>
            }

        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private string _graphSearchQuery = string.Empty;
    private bool _isGraphLoading = false;
    
    // 💡 NEW: Holds the analytics reference state
    private GraphMetricsDto? _graphMetrics;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadGraphDataAsync();
        }
    }

    private async Task LoadGraphDataAsync(string filter = "")
    {
        _isGraphLoading = true;
        StateHasChanged();

        try
        {
            var graphData = await Mediator.Send(new GetEntityGraphQuery(filter));
            
            // Capture the metrics data packet from the response pipeline
            _graphMetrics = graphData.Metrics;

            await Task.Delay(150);
            await JSRuntime.InvokeVoidAsync("window.eivaGraphInterop.renderNetworkGraph", "eivaGraphViewport", graphData.Nodes, graphData.Edges);
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Graph execution failure: {ex.Message}");
        }
        finally
        {
            _isGraphLoading = false;
            StateHasChanged();
        }
    }

    private async Task HandleGraphSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await LoadGraphDataAsync(_graphSearchQuery);
        }
    }
}