@page "/visualization"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer

@using MediatR
@using AskEiva.Application.Telemetry.Queries
@using AskEiva.Application.ReleaseNotes.Commands
@inject IMediator Mediator
@inject ISnackbar Snackbar

<PageTitle>EIVA telemetry cockpit</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudGrid>
        
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="0" Class="pa-4 d-flex align-center justify-space-between" Style="border: 1px solid #E2E8F0; border-radius: 8px;">
                <div>
                    <MudText Typo="Typo.caption" Class="font-weight-bold" Style="color: #64748B; text-transform: uppercase;">Document Library</MudText>
                    <MudText Typo="Typo.h4" Class="font-weight-bold" Style="color: #0A2540;">@_documentCount.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Style="color: #059669;">● Unique Documentation</MudText>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.LibraryBooks" Style="color: #E2E8F0; font-size: 3rem;" />
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="4">
            <MudPaper Elevation="0" Class="pa-4 d-flex align-center justify-space-between" Style="border: 1px solid #E2E8F0; border-radius: 8px;">
                <div>
                    <MudText Typo="Typo.caption" Class="font-weight-bold" Style="color: #64748B; text-transform: uppercase;">Unique Tickets</MudText>
                    <MudText Typo="Typo.h4" Class="font-weight-bold" Style="color: #0A2540;">@_ticketCount.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Style="color: #0284C7;">● Vectorized for AskEiva</MudText>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.ConfirmationNumber" Style="color: #E2E8F0; font-size: 3rem;" />
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="4">
            <MudPaper Elevation="0" Class="pa-4 d-flex align-center justify-space-between" Style="border: 1px solid #E2E8F0; border-radius: 8px;">
                <div>
                    <MudText Typo="Typo.caption" Class="font-weight-bold" Style="color: #64748B; text-transform: uppercase;">Total User Dialogue</MudText>
                    <MudText Typo="Typo.h4" Class="font-weight-bold" Style="color: #0A2540;">@_interactionLogs.Count.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Style="color: #7C3AED;">● Dialogue captured</MudText>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.AssignmentTurnedIn" Style="color: #E2E8F0; font-size: 3rem;" />
            </MudPaper>
        </MudItem>

        <MudItem xs="12">
            <MudPaper Elevation="0" Class="pa-4" Style="border: 1px solid #E2E8F0; border-radius: 8px; background: #FFFFFF;">
                <div class="d-flex align-center justify-space-between mb-4">
                    <div class="d-flex align-center gap-3">
                        <MudIcon Icon="@Icons.Material.Filled.HistoryEdu" Color="Color.Primary" />
                        <MudText Typo="Typo.h6" Style="color: #0A2540; font-weight: 600;">Conversation Log</MudText>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <MudButton Variant="Variant.Filled" 
                                   Color="Color.Primary" 
                                   Size="Size.Small" 
                                   StartIcon="@Icons.Material.Filled.CloudDownload" 
                                   OnClick="TriggerReleaseNotesScrapeAsync"
                                   Disabled="_isScraping">
                            @(_isScraping ? "Processing PDF..." : "Sync Release Notes")
                        </MudButton>

                        <MudButton Variant="Variant.Outlined" 
                                   Color="Color.Primary" 
                                   Size="Size.Small" 
                                   StartIcon="@Icons.Material.Filled.Refresh" 
                                   OnClick="FetchDashboardTelemetryAsync"
                                   Disabled="_isLoading">
                            @(_isLoading ? "Querying..." : "Refresh Logs")
                        </MudButton>
                    </div>
                </div>

                <MudDataGrid Items="@_interactionLogs" 
                             T="InteractionLogItemDto" 
                             Loading="_isLoading" 
                             Bordered="false" 
                             Dense="true" 
                             Hover="true"
                             Filterable="true" 
                             FilterMode="DataGridFilterMode.ColumnFilterMenu">
                    <Columns>
                        <HierarchyColumn T="InteractionLogItemDto" />
                        
                        <PropertyColumn Property="x => x.Timestamp" 
                                        Title="Timestamp" 
                                        Format="yyyy-MM-dd HH:mm:ss" 
                                        Sortable="true" 
                                        HeaderStyle="color: #0A2540; font-weight: bold; width: 180px;" />
                        
                        <PropertyColumn Property="x => x.UserPrompt" 
                                        Title="User Question" 
                                        Sortable="true" 
                                        HeaderStyle="color: #0A2540; font-weight: bold;" />
                        
                        <PropertyColumn Property="x => x.CopilotResponse" 
                                        Title="Response Snippet" 
                                        Sortable="false" 
                                        Filterable="false"
                                        HeaderStyle="color: #0A2540; font-weight: bold;" 
                                        CellStyle="text-overflow: ellipsis; max-width: 300px; white-space: nowrap; overflow: hidden;" />
                        
                        <PropertyColumn Property="x => x.FeedbackState" 
                                        Title="Feedback" 
                                        Sortable="true" 
                                        HeaderStyle="color: #0A2540; font-weight: bold; width: 140px;" />
                        
                        <PropertyColumn Property="x => x.ModelUsed" 
                                        Title="Model" 
                                        Sortable="true" 
                                        HeaderStyle="color: #0A2540; font-weight: bold; width: 160px;" />
                    </Columns>
                    <ChildRowContent>
                        <MudCard Style="background: #F8FAFC; border-radius: 0; box-shadow: none; border-top: 1px solid #E2E8F0;" Class="pa-4">
                            <MudGrid>
                                <MudItem xs="12">
                                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold mb-1" Style="color: #0A2540;">📥 User Prompt:</MudText>
                                    <div class="pa-3 mb-3 bg-white border rounded" style="color: #334155; font-size: 0.9rem; line-height: 1.5;">
                                        @context.Item.UserPrompt
                                    </div>
                                    
                                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold mb-1" Style="color: #0A2540;">🤖 AskEIVA Response:</MudText>
                                    <div class="pa-3 bg-white border rounded" style="color: #334155; font-size: 0.9rem; line-height: 1.5; white-space: pre-wrap;">
                                        @context.Item.CopilotResponse
                                    </div>
                                </MudItem>
                            </MudGrid>
                        </MudCard>
                    </ChildRowContent>
                    <PagerContent>
                        <MudDataGridPager T="InteractionLogItemDto" PageSizeOptions="new int[]{5, 10, 20}" />
                    </PagerContent>
                </MudDataGrid>
            </MudPaper>
        </MudItem>
        
    </MudGrid>
</MudContainer>

@code {
    private bool _isLoading = false;
    private bool _isScraping = false;
    private int _documentCount = 0;
    private int _ticketCount = 0;
    private List<InteractionLogItemDto> _interactionLogs = new();

    protected override async Task OnInitializedAsync()
    {
        await FetchDashboardTelemetryAsync();
    }

    private async Task FetchDashboardTelemetryAsync()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            // Connect directly to the application layer handler query pipeline
            var result = await Mediator.Send(new GetDashboardTelemetryQuery());
            
            _documentCount = result.TotalUniqueDocuments;
            _ticketCount = result.TotalUniqueTickets;
            _interactionLogs = result.Logs;
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Telemetry load error: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

private async Task TriggerReleaseNotesScrapeAsync()
    {
        _isScraping = true;
        StateHasChanged();

        try
        {
            // Dispatch the automated delta ingestion architecture pipeline via MediatR handlers
            var result = await Mediator.Send(new IngestReleaseNotesCommand());
            
            // 💡 DEFENSIVE GUARD CHECK: Prevent NullReferenceException if the handler returns default/null
            if (result is null)
            {
                System.Diagnostics.Debug.WriteLine("[Telemetry Cockpit Warning] IngestReleaseNotesCommand returned a null response payload.");
                Snackbar?.Add("Ingestion sequence completed with an unreadable empty return payload.", Severity.Warning);
                return;
            }

            // Guard the Snackbar popup call safely in case the MudBlazor provider service mapping isn't fully initialized
            if (result.IsSuccess)
            {
                if (result.TotalChunksIngested > 0)
                {
                    Snackbar?.Add(result.StatusDetails ?? "Ingestion completed successfully.", Severity.Success);
                }
                else
                {
                    Snackbar?.Add(result.StatusDetails ?? "Delta Check: Version already processed. Skipped.", Severity.Warning);
                }
            }
            else
            {
                Snackbar?.Add(result.StatusDetails ?? "Ingestion processing encountered an anomaly.", Severity.Error);
            }

            // Instantly refresh the visual tracking metrics arrays inside your dashboard view card
            await FetchDashboardTelemetryAsync();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"[Scraping Pipeline Fault] Exception intercepted: {ex.Message}");
            Snackbar?.Add($"Scraping pipeline faulted: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isScraping = false;
            StateHasChanged();
        }
    }
}