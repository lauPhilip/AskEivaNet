@page "/visualization"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@implements IDisposable

@using MediatR
@using AskEiva.Application.Telemetry
@using AskEiva.Application.Telemetry.Queries
@using AskEiva.Application.ReleaseNotes.Commands
@using AskEiva.Application.Tickets.Commands
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject ISyncTelemetryBroker TelemetryBroker

<PageTitle>EIVA telemetry cockpit</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudGrid>
        
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="0" Class="pa-4 d-flex align-center justify-space-between" Style="border: 1px solid #E2E8F0; border-radius: 8px;">
                <div>
                    <MudText Typo="Typo.caption" Class="font-weight-bold" Style="color: #64748B; text-transform: uppercase;">Document Library</MudText>
                    <MudText Typo="Typo.h4" Class="font-weight-bold" Style="color: #0A2540;">@_documentCount.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Style="color: #059669;">● Unique Documentation</MudText>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.LibraryBooks" Style="color: #E2E8F0; font-size: 3rem;" />
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="4">
            <MudPaper Elevation="0" Class="pa-4 d-flex align-center justify-space-between" Style="border: 1px solid #E2E8F0; border-radius: 8px;">
                <div>
                    <MudText Typo="Typo.caption" Class="font-weight-bold" Style="color: #64748B; text-transform: uppercase;">Unique Tickets</MudText>
                    <MudText Typo="Typo.h4" Class="font-weight-bold" Style="color: #0A2540;">@_ticketCount.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Style="color: #0284C7;">● Vectorized for AskEiva</MudText>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.ConfirmationNumber" Style="color: #E2E8F0; font-size: 3rem;" />
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="4">
            <MudPaper Elevation="0" Class="pa-4 d-flex align-center justify-space-between" Style="border: 1px solid #E2E8F0; border-radius: 8px;">
                <div>
                    <MudText Typo="Typo.caption" Class="font-weight-bold" Style="color: #64748B; text-transform: uppercase;">Total User Dialogue</MudText>
                    <MudText Typo="Typo.h4" Class="font-weight-bold" Style="color: #0A2540;">@_interactionLogs.Count.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Style="color: #7C3AED;">● Dialogue captured</MudText>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.AssignmentTurnedIn" Style="color: #E2E8F0; font-size: 3rem;" />
            </MudPaper>
        </MudItem>

        <MudItem xs="12">
            <MudPaper Elevation="0" Class="pa-4" Style="border: 1px solid #E2E8F0; border-radius: 8px; background: #FFFFFF;">
                <div class="d-flex align-center justify-space-between mb-4">
                    <div class="d-flex align-center gap-3">
                        <MudIcon Icon="@Icons.Material.Filled.HistoryEdu" Color="Color.Primary" />
                        <MudText Typo="Typo.h6" Style="color: #0A2540; font-weight: 600;">Conversation Log</MudText>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <MudButton Variant="Variant.Filled" 
                                   Color="Color.Primary" 
                                   Size="Size.Small" 
                                   StartIcon="@Icons.Material.Filled.CloudDownload" 
                                   OnClick="TriggerReleaseNotesScrapeAsync"
                                   Disabled="_isScraping">
                            @(_isScraping ? "Processing PDF..." : "Sync Release Notes")
                        </MudButton>

                        <MudButton Variant="Variant.Outlined" 
                                   Color="Color.Primary" 
                                   Size="Size.Small" 
                                   StartIcon="@Icons.Material.Filled.Refresh" 
                                   OnClick="FetchDashboardTelemetryAsync"
                                   Disabled="_isLoading">
                            @(_isLoading ? "Querying..." : "Refresh Logs")
                        </MudButton>
                    </div>
                </div>

                <MudDataGrid Items="@_interactionLogs" 
                             T="InteractionLogItemDto" 
                             Loading="_isLoading" 
                             Bordered="false" 
                             Dense="true" 
                             Hover="true"
                             Filterable="true" 
                             FilterMode="DataGridFilterMode.ColumnFilterMenu">
                    <Columns>
                        <HierarchyColumn T="InteractionLogItemDto" />
                        
                        <PropertyColumn Property="x => x.Timestamp" 
                                        Title="Timestamp" 
                                        Format="yyyy-MM-dd HH:mm:ss" 
                                        Sortable="true" 
                                        HeaderStyle="color: #0A2540; font-weight: bold; width: 180px;" />
                        
                        <PropertyColumn Property="x => x.UserPrompt" 
                                        Title="User Question" 
                                        Sortable="true" 
                                        HeaderStyle="color: #0A2540; font-weight: bold;" />
                        
                        <PropertyColumn Property="x => x.CopilotResponse" 
                                        Title="Response Snippet" 
                                        Sortable="false" 
                                        Filterable="false"
                                        HeaderStyle="color: #0A2540; font-weight: bold;" 
                                        CellStyle="text-overflow: ellipsis; max-width: 300px; white-space: nowrap; overflow: hidden;" />
                        
                        <PropertyColumn Property="x => x.FeedbackState" 
                                        Title="Feedback" 
                                        Sortable="true" 
                                        HeaderStyle="color: #0A2540; font-weight: bold; width: 140px;" />
                        
                        <PropertyColumn Property="x => x.ModelUsed" 
                                        Title="Model" 
                                        Sortable="true" 
                                        HeaderStyle="color: #0A2540; font-weight: bold; width: 160px;" />
                    </Columns>
                    <ChildRowContent>
                        <MudCard Style="background: #F8FAFC; border-radius: 0; box-shadow: none; border-top: 1px solid #E2E8F0;" Class="pa-4">
                            <MudGrid>
                                <MudItem xs="12">
                                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold mb-1" Style="color: #0A2540;">📥 User Prompt:</MudText>
                                    <div class="pa-3 mb-3 bg-white border rounded" style="color: #334155; font-size: 0.9rem; line-height: 1.5;">
                                        @context.Item.UserPrompt
                                    </div>
                                    
                                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold mb-1" Style="color: #0A2540;">🤖 AskEIVA Response:</MudText>
                                    <div class="pa-3 bg-white border rounded" style="color: #334155; font-size: 0.9rem; line-height: 1.5; white-space: pre-wrap;">
                                        @context.Item.CopilotResponse
                                    </div>
                                </MudItem>
                            </MudGrid>
                        </MudCard>
                    </ChildRowContent>
                    <PagerContent>
                        <MudDataGridPager T="InteractionLogItemDto" PageSizeOptions="new int[]{5, 10, 20}" />
                    </PagerContent>
                </MudDataGrid>
            </MudPaper>
        </MudItem>

        <MudItem xs="12">
            <MudPaper Elevation="0" Class="pa-4" Style="border: 1px solid #E2E8F0; border-radius: 8px; background: #FFFFFF;">
                <div class="d-flex align-center justify-space-between mb-4">
                    <div class="d-flex align-center gap-3">
                        <MudIcon Icon="@Icons.Material.Filled.SyncProblem" Color="Color.Info" />
                        <MudText Typo="Typo.h6" Style="color: #0A2540; font-weight: 600;">Freshdesk Core Ticket Sync Engine</MudText>
                    </div>
                    <MudButton Variant="Variant.Filled" 
                               Color="Color.Info" 
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.PlayCircleFilled"
                               OnClick="TriggerTicketIngestionPipeline"
                               Disabled="@_isSyncing">
                        @(_isSyncing ? "Crawling Matrix..." : "Run Production Sync")
                    </MudButton>
                </div>

                <MudGrid Class="mb-4">
                    <MudItem xs="12" sm="4">
                        <MudPaper Class="pa-3 text-center" Style="background: #F8FAFC; border: 1px solid #E2E8F0; border-radius: 6px;">
                            <MudText Typo="Typo.caption" Class="font-weight-bold" Style="color: #64748B; text-transform: uppercase;">Current Crawl Page</MudText>
                            <MudText Typo="Typo.h5" Class="font-weight-bold mt-1" Style="color: #0A2540;">@_activePage</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudPaper Class="pa-3 text-center" Style="background: #F8FAFC; border: 1px solid #E2E8F0; border-radius: 6px;">
                            <MudText Typo="Typo.caption" Class="font-weight-bold" Style="color: #64748B; text-transform: uppercase;">Last Ticket Parsed</MudText>
                            <MudText Typo="Typo.h5" Class="font-weight-bold mt-1" Style="color: #0284C7; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@_lastProcessedId</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudPaper Class="pa-3 text-center" Style="background: #F8FAFC; border: 1px solid #E2E8F0; border-radius: 6px;">
                            <MudText Typo="Typo.caption" Class="font-weight-bold" Style="color: #64748B; text-transform: uppercase;">Total New Chunks Indexed</MudText>
                            <MudText Typo="Typo.h5" Class="font-weight-bold mt-1" Style="color: #16A34A;">@_totalChunksCommitted</MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                <MudText Typo="Typo.caption" Class="font-weight-bold d-block mb-1" Style="color: #64748B;">Live Processing Stream Logs:</MudText>
                <div style="background: #0F172A; color: #38BDF8; font-family: monospace; font-size: 0.8rem; padding: 12px; height: 160px; overflow-y: auto; border-radius: 6px; border: 1px solid #1E293B;" class="mb-4">
                    @foreach (var log in _liveLogStream)
                    {
                        <div class="mb-1">
                            <span style="color: #64748B;">[@DateTime.Now.ToString("HH:mm:ss")]</span> @log
                        </div>
                    }
                    @if (_liveLogStream.Count == 0)
                    {
                        <div style="color: #64748B;">Console engine idle. Awaiting sync execution trigger signal initialization...</div>
                    }
                </div>

                <MudText Typo="Typo.caption" Class="font-weight-bold d-block mb-1" Style="color: #64748B;">Active Ingestion Node Monitoring Grid:</MudText>
                <MudTable Items="@_processedTicketsHistory" Dense="true" Hover="true" Bordered="false" Elevation="0" Style="border: 1px solid #E2E8F0; border-radius: 6px;" Height="220px" FixedHeader="true">
                    <HeaderContent>
                        <MudTh Style="color: #0A2540; font-weight: bold;">Ticket ID</MudTh>
                        <MudTh Style="color: #0A2540; font-weight: bold;">Subject Reference</MudTh>
                        <MudTh Style="color: #0A2540; font-weight: bold; text-align: right;">Chunks Extracted</MudTh>
                        <MudTh Style="color: #0A2540; font-weight: bold; text-align: center;">Sync State</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Ticket ID" Class="font-weight-bold" Style="color: #0A2540;">@context.CurrentTicketId</MudTd>
                        <MudTd DataLabel="Subject Reference" Style="max-width: 500px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: #334155;">@context.TicketSubject</MudTd>
                        <MudTd DataLabel="Chunks Extracted" style="text-align: right; font-family: monospace; font-weight: bold; color: #0284C7;">@context.ChunksGenerated</MudTd>
                        <MudTd DataLabel="Sync State" style="text-align: center;">
                            <span class="status-badge @context.Status.ToLower()">@context.Status</span>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>
        
    </MudGrid>
</MudContainer>

<style>
    .status-badge { display: inline-block; padding: 2px 6px; border-radius: 4px; font-size: 10px; font-weight: bold; text-transform: uppercase; }
    .status-badge.processing { background: #FEF3C7; color: #D97706; }
    .status-badge.success { background: #DCFCE7; color: #16A34A; }
    .status-badge.skip { background: #F1F5F9; color: #475569; }
    .status-badge.complete { background: #DBEAFE; color: #2563EB; }
</style>

@code {
    private bool _isLoading = false;
    private bool _isScraping = false;
    private int _documentCount = 0;
    private int _ticketCount = 0;
    private List<InteractionLogItemDto> _interactionLogs = new();

    // 💡 REBORN BROADCAST TELEMETRY PROPERTIES
    private bool _isSyncing = false;
    private int _activePage = 1;
    private string _lastProcessedId = "FD-None";
    private int _totalChunksCommitted = 0;
    private List<string> _liveLogStream = new();
    private List<SyncProgressUpdate> _processedTicketsHistory = new();

    protected override async Task OnInitializedAsync()
    {
        // Bind the singleton execution broker state actions natively on thread hooks
        TelemetryBroker.OnProgressUpdated += HandleSyncProgressNotification;
        await FetchDashboardTelemetryAsync();
    }

    private void HandleSyncProgressNotification(SyncProgressUpdate update)
    {
        InvokeAsync(() =>
        {
            if (!string.IsNullOrWhiteSpace(update.LogMessage))
            {
                _liveLogStream.Add(update.LogMessage);
                if (_liveLogStream.Count > 100) _liveLogStream.RemoveAt(0);
            }

            if (update.CurrentPage > 0) _activePage = update.CurrentPage;
            if (update.TotalChunksIndexed > 0) _totalChunksCommitted = update.TotalChunksIndexed;

            if (!string.IsNullOrEmpty(update.CurrentTicketId))
            {
                _lastProcessedId = update.CurrentTicketId;
                
                var existingRow = _processedTicketsHistory.FirstOrDefault(t => t.CurrentTicketId == update.CurrentTicketId);
                if (existingRow != null)
                {
                    existingRow.ChunksGenerated = update.ChunksGenerated;
                    existingRow.Status = update.Status;
                }
                else
                {
                    _processedTicketsHistory.Insert(0, update); // New metrics cascade straight to the top row
                }
            }

            if (update.Status == "Complete") _isSyncing = false;

            StateHasChanged();
        });
    }

    private async Task FetchDashboardTelemetryAsync()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            var result = await Mediator.Send(new GetDashboardTelemetryQuery());
            _documentCount = result.TotalUniqueDocuments;
            _ticketCount = result.TotalUniqueTickets;
            _interactionLogs = result.Logs;
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Telemetry load error: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

private async Task TriggerTicketIngestionPipeline()
    {
        _isSyncing = true;
        _liveLogStream.Clear();
        _processedTicketsHistory.Clear();
        StateHasChanged();

        try
        {
            // 💡 FORCES EXECUTION PASS ACROSS THE ENTIRE HISTORICAL TIMELINE
            await Mediator.Send(new IngestTicketsCommand());
            Snackbar?.Add("Global historical support tickets sync sweep successfully completed.", Severity.Success);
            await FetchDashboardTelemetryAsync();
        }
        catch (Exception ex)
        {
            Snackbar?.Add($"Ticket sync channel faulted: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSyncing = false;
            StateHasChanged();
        }
    }

    private async Task TriggerReleaseNotesScrapeAsync()
    {
        _isScraping = true;
        StateHasChanged();

        try
        {
            var result = await Mediator.Send(new IngestReleaseNotesCommand());
            
            if (result is null)
            {
                System.Diagnostics.Debug.WriteLine("[Telemetry Cockpit Warning] IngestReleaseNotesCommand returned a null response payload.");
                Snackbar?.Add("Ingestion sequence completed with an unreadable empty return payload.", Severity.Warning);
                return;
            }

            if (result.IsSuccess)
            {
                if (result.TotalChunksIngested > 0)
                {
                    Snackbar?.Add(result.StatusDetails ?? "Ingestion completed successfully.", Severity.Success);
                }
                else
                {
                    Snackbar?.Add(result.StatusDetails ?? "Delta Check: Version already processed. Skipped.", Severity.Warning);
                }
            }
            else
            {
                Snackbar?.Add(result.StatusDetails ?? "Ingestion processing encountered an anomaly.", Severity.Error);
            }

            await FetchDashboardTelemetryAsync();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"[Scraping Pipeline Fault] Exception intercepted: {ex.Message}");
            Snackbar?.Add($"Scraping pipeline faulted: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isScraping = false;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        // Unsubscribe safely to prevent runtime background component memory leakage loops
        TelemetryBroker.OnProgressUpdated -= HandleSyncProgressNotification;
    }
}